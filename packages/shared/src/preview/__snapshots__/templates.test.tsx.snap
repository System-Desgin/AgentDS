0;padding:3px 10px;background-color:#24A148;color:#161616">On track</span></td></tr><tr><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px"><div>Billing migration</div><div style="color:#0A2540;font-size:11px">5 hours ago</div></td><td style="border-bottom:1px solid #F4F4F4;font-family:ui-monospace, monospace;padding:9px 4px">$48,700</td><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px;text-align:right"><span style="border-radius:999px;font-size:11px;font-weight:600;padding:3px 10px;background-color:#24A148;color:#161616">On track</span></td></tr><tr><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px"><div>APAC expansion</div><div style="color:#0A2540;font-size:11px">Yesterday</div></td><td style="border-bottom:1px solid #F4F4F4;font-family:ui-monospace, monospace;padding:9px 4px">$27,600</td><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px;text-align:right"><span style="border-radius:999px;font-size:11px;font-weight:600;padding:3px 10px;background-color:#B36200;color:#FFFFFF">At risk</span></td></tr><tr><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px"><div>Legacy sunset</div><div style="color:#0A2540;font-size:11px">2 days ago</div></td><td style="border-bottom:1px solid #F4F4F4;font-family:ui-monospace, monospace;padding:9px 4px">$12,300</td><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px;text-align:right"><span style="border-radius:999px;font-size:11px;font-weight:600;padding:3px 10px;background-color:#DA1E28;color:#FFFFFF">Blocked</span></td></tr></tbody></table><div style="margin-top:12px"><span style="color:#0A2540;font-size:13px">View all activity →</span></div></section></div></main></div><div style="align-items:center;background-color:#F4F4F4;display:flex;font-family:&quot;Inter&quot;, system-ui, sans-serif;justify-content:center;min-height:640px;padding:32px"><div style="background-color:#F6F9FC;border:1px solid #F4F4F4;border-radius:8px;display:grid;grid-template-columns:1fr 1fr;max-width:860px;overflow:hidden;width:100%"><div style="background-color:#0A2540;color:#FFFFFF;display:flex;flex-direction:column;gap:16px;justify-content:flex-end;padding:32px"><span style="background-color:#FFFFFF;border-radius:4px;height:28px;opacity:0.9;width:28px"></span><div style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:28px;font-weight:700;line-height:1.2">Ship on-system UI from day one.</div><div style="font-size:14px">One account for every workspace, report, and integration in Fixture.</div></div><div style="display:flex;flex-direction:column;gap:16px;padding:32px"><div><h1 style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:22px;font-weight:700;margin:0">Sign in</h1><div style="color:#0A2540;font-size:13px;margin-top:6px">New here? <span style="color:#0A2540">Create an account</span></div></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#0A2540;font-size:12px;letter-spacing:0.02em">Email</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#0A2540;font-size:14px;padding:10.4px 12px">ada@example.com</span></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#0A2540;font-size:12px;letter-spacing:0.02em">Password</span><span style="background-color:#F4F4F4;border:1px solid #0A2540;border-radius:4px;box-shadow:0 0 0 2px #0A254033;color:#0A2540;font-size:14px;padding:10.4px 12px">••••••••••</span></div><div style="align-items:center;display:flex;justify-content:space-between"><span style="align-items:center;display:inline-flex;gap:8px"><span style="background-color:#0A2540;border-radius:999px;display:inline-flex;height:20px;justify-content:flex-end;padding:2px;width:36px"><span style="background-color:#FFFFFF;border-radius:999px;height:16px;width:16px"></span></span><span style="color:#0A2540;font-size:13px">Remember me</span></span><span style="color:#0A2540;font-size:13px">Forgot password?</span></div><span style="border-radius:4px;display:inline-block;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;background-color:#0A2540;color:#FFFFFF">Sign in</span><div style="align-items:center;display:flex;gap:12px"><span style="background-color:#F4F4F4;flex:1;height:1px"></span><span style="color:#0A2540;font-size:12px">or</span><span style="background-color:#F4F4F4;flex:1;height:1px"></span></div><span style="border-radius:4px;display:inline-block;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;border:1px solid #F4F4F4;color:#0A2540">Continue with SSO</span><div style="color:#0A2540;font-size:12px;line-height:1.5">Protected by two-factor authentication. By continuing you agree to the terms of service.</div></div></div></div><div style="background-color:#F6F9FC;color:#0A2540;font-family:&quot;Inter&quot;, system-ui, sans-serif;min-height:640px;padding:24px"><div style="margin:0 auto;max-width:760px"><div style="color:#0A2540;font-size:12px;margin-bottom:4px">Fixture / Settings</div><h1 style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:24px;font-weight:700;margin:0">Account settings</h1><div style="border-bottom:1px solid #F4F4F4;display:flex;gap:4px;margin-top:16px"><span style="border-bottom:2px solid #0A2540;color:#0A2540;font-size:14px;font-weight:600;padding:9.6px 12px">Profile</span><span style="border-bottom:2px solid transparent;color:#0A2540;font-size:14px;font-weight:400;padding:9.6px 12px">Workspace</span><span style="border-bottom:2px solid transparent;color:#0A2540;font-size:14px;font-weight:400;padding:9.6px 12px">Notifications</span><span style="border-bottom:2px solid transparent;color:#0A2540;font-size:14px;font-weight:400;padding:9.6px 12px">Billing</span><span style="border-bottom:2px solid transparent;color:#0A2540;font-size:14px;font-weight:400;padding:9.6px 12px">API</span></div><section style="display:flex;flex-direction:column;gap:16px;padding-top:20px"><div style="align-items:center;display:flex;gap:16px"><span style="align-items:center;background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:999px;color:#0A2540;display:inline-flex;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:22px;font-weight:700;height:56px;justify-content:center;width:56px">A</span><div><div style="font-size:15px;font-weight:600">Ada Lovelace</div><div style="color:#0A2540;font-size:13px">Owner · joined March 2025</div></div><span style="margin-left:auto"><span style="border-radius:4px;display:inline-block;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;border:1px solid #F4F4F4;color:#0A2540">Change avatar</span></span></div><div style="display:grid;gap:16px;grid-template-columns:1fr 1fr"><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#0A2540;font-size:12px;letter-spacing:0.02em">Full name</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#0A2540;font-size:14px;padding:10.4px 12px">Ada Lovelace</span></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#0A2540;font-size:12px;letter-spacing:0.02em">Email</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#0A2540;font-size:14px;padding:10.4px 12px">ada@example.com</span></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#0A2540;font-size:12px;letter-spacing:0.02em">Role</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#0A2540;font-size:14px;padding:10.4px 12px">Owner</span></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#0A2540;font-size:12px;letter-spacing:0.02em">Timezone</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#0A2540;font-size:14px;padding:10.4px 12px">UTC+03:00 — Riyadh</span></div></div><div style="background-color:#F4F4F4;border-radius:8px;display:flex;flex-direction:column;gap:12px;padding:16px"><div style="align-items:center;display:flex;gap:16px"><div style="flex:1"><div style="font-size:14px;font-weight:500">Product updates</div><div style="color:#0A2540;font-size:12px">Release notes and new catalog entries</div></div><span style="background-color:#0A2540;border-radius:999px;display:inline-flex;height:20px;justify-content:flex-end;padding:2px;width:36px"><span style="background-color:#FFFFFF;border-radius:999px;height:16px;width:16px"></span></span></div><div style="align-items:center;display:flex;gap:16px"><div style="flex:1"><div style="font-size:14px;font-weight:500">Usage reports</div><div style="color:#0A2540;font-size:12px">Weekly summary of fetches and installs</div></div><span style="background-color:#0A2540;border-radius:999px;display:inline-flex;height:20px;justify-content:flex-end;padding:2px;width:36px"><span style="background-color:#FFFFFF;border-radius:999px;height:16px;width:16px"></span></span></div><div style="align-items:center;display:flex;gap:16px"><div style="flex:1"><div style="font-size:14px;font-weight:500">Security alerts</div><div style="color:#0A2540;font-size:12px">Sign-ins from new devices</div></div><span style="background-color:#F4F4F4;border-radius:999px;display:inline-flex;height:20px;justify-content:flex-start;padding:2px;width:36px"><span style="background-color:#FFFFFF;border-radius:999px;height:16px;width:16px"></span></span></div></div><div style="border:1px solid #DA1E28;border-radius:8px;display:flex;gap:16px;justify-content:space-between;padding:16px"><div><div style="color:#DA1E28;font-size:14px;font-weight:600">Delete workspace</div><div style="color:#0A2540;font-size:12px;margin-top:4px">Removes every report and API key. This cannot be undone.</div></div><span style="border-radius:4px;display:inline-block;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;background-color:#DA1E28;color:#FFFFFF">Delete</span></div><div style="display:flex;gap:10px;justify-content:flex-end"><span style="border-radius:4px;display:inline-block;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;border:1px solid #F4F4F4;color:#0A2540">Cancel</span><span style="border-radius:4px;display:inline-block;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;background-color:#0A2540;color:#FFFFFF">Save changes</span></div></section></div></div></div>"`;

exports[`sample templates > renders every template for the official fixture (snapshot) 1`] = `"<div><div style="background-color:#FFFFFF;color:#161616;display:grid;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;grid-template-columns:220px 1fr;min-height:640px"><aside style="border-right:1px solid #F4F4F4;display:flex;flex-direction:column;gap:24px;padding:20px"><div style="align-items:center;display:flex;gap:10px"><span style="background-color:#0F62FE;border-radius:4px;height:22px;width:22px"></span><span style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:15px;font-weight:600">Fixture</span></div><nav style="display:flex;flex-direction:column;gap:4px"><span style="background-color:#F4F4F4;border-left:3px solid #0F62FE;border-radius:4px;color:#161616;font-size:14px;padding:8px 12px">Overview</span><span style="border-left:3px solid transparent;border-radius:4px;color:#161616;font-size:14px;padding:8px 12px">Reports</span><span style="border-left:3px solid transparent;border-radius:4px;color:#161616;font-size:14px;padding:8px 12px">Customers</span><span style="border-left:3px solid transparent;border-radius:4px;color:#161616;font-size:14px;padding:8px 12px">Billing</span><span style="border-left:3px solid transparent;border-radius:4px;color:#161616;font-size:14px;padding:8px 12px">Settings</span></nav><div style="border-top:1px solid #F4F4F4;margin-top:auto;padding-top:16px"><span style="color:#161616;font-size:12px">help@example.com</span></div></aside><main style="display:flex;flex-direction:column;gap:24px;padding:24px"><header style="align-items:center;display:flex;justify-content:space-between"><div><div style="color:#161616;font-size:12px;margin-bottom:4px">Analytics / Revenue</div><h1 style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:24px;font-weight:600;margin:0">Revenue dashboard</h1></div><div style="display:flex;gap:10px"><span style="border-radius:4px;display:inline-block;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;border:1px solid #F4F4F4;color:#161616">Export</span><span style="border-radius:4px;display:inline-block;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;background-color:#0F62FE;color:#FFFFFF">Create report</span></div></header><div style="display:grid;gap:16px;grid-template-columns:repeat(4, 1fr)"><div style="background-color:#F4F4F4;border-radius:4px;padding:16px"><div style="color:#161616;font-size:12px">Revenue</div><div style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:26px;font-weight:600;margin-top:8px">$128.4K</div><div style="color:#161616;font-size:12px;margin-top:8px">▲ 12.5% vs last month</div></div><div style="background-color:#F4F4F4;border-radius:4px;padding:16px"><div style="color:#161616;font-size:12px">Customers</div><div style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:26px;font-weight:600;margin-top:8px">2,847</div><div style="color:#161616;font-size:12px;margin-top:8px">▲ 8.1% vs last month</div></div><div style="background-color:#F4F4F4;border-radius:4px;padding:16px"><div style="color:#161616;font-size:12px">Average order</div><div style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:26px;font-weight:600;margin-top:8px">$45.10</div><div style="color:#161616;font-size:12px;margin-top:8px">▲ 3.2% vs last month</div></div><div style="background-color:#F4F4F4;border-radius:4px;padding:16px"><div style="color:#161616;font-size:12px">Churn</div><div style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:26px;font-weight:600;margin-top:8px">1.9%</div><div style="color:#DA1E28;font-size:12px;margin-top:8px">▲ 0.2% vs last month</div></div></div><div style="display:grid;gap:16px;grid-template-columns:3fr 2fr"><section style="border:1px solid #F4F4F4;border-radius:4px;padding:16px"><h2 style="font-size:14px;font-weight:600;margin:0 0 16px">Monthly performance</h2><div style="align-items:flex-end;border-bottom:1px solid #F4F4F4;display:flex;gap:8px;height:170px"><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:42%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:58%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:50%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:74%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:66%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:88%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:79%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:96%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:84%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:70%"></div><div style="background-color:#0F62FE99;border-radius:4px 4px 0 0;flex:1;height:90%"></div><div style="background-color:#0F62FE;border-radius:4px 4px 0 0;flex:1;height:100%"></div></div><div style="color:#161616;display:flex;font-size:11px;justify-content:space-between;margin-top:8px"><span>Jan</span><span>Jun</span><span>Dec</span></div></section><section style="border:1px solid #F4F4F4;border-radius:4px;padding:16px"><h2 style="font-size:14px;font-weight:600;margin:0 0 16px">Recent activity</h2><table style="border-collapse:collapse;font-size:13px;width:100%"><tbody><tr><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px"><div>Aurora rollout</div><div style="color:#161616;font-size:11px">2 hours ago</div></td><td style="border-bottom:1px solid #F4F4F4;font-family:&quot;IBM Plex Mono&quot;, ui-monospace, monospace;padding:9px 4px">$52,140</td><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px;text-align:right"><span style="border-radius:999px;font-size:11px;font-weight:600;padding:3px 10px;background-color:#24A148;color:#161616">On track</span></td></tr><tr><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px"><div>Billing migration</div><div style="color:#161616;font-size:11px">5 hours ago</div></td><td style="border-bottom:1px solid #F4F4F4;font-family:&quot;IBM Plex Mono&quot;, ui-monospace, monospace;padding:9px 4px">$48,700</td><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px;text-align:right"><span style="border-radius:999px;font-size:11px;font-weight:600;padding:3px 10px;background-color:#24A148;color:#161616">On track</span></td></tr><tr><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px"><div>APAC expansion</div><div style="color:#161616;font-size:11px">Yesterday</div></td><td style="border-bottom:1px solid #F4F4F4;font-family:&quot;IBM Plex Mono&quot;, ui-monospace, monospace;padding:9px 4px">$27,600</td><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px;text-align:right"><span style="border-radius:999px;font-size:11px;font-weight:600;padding:3px 10px;background-color:#B36200;color:#FFFFFF">At risk</span></td></tr><tr><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px"><div>Legacy sunset</div><div style="color:#161616;font-size:11px">2 days ago</div></td><td style="border-bottom:1px solid #F4F4F4;font-family:&quot;IBM Plex Mono&quot;, ui-monospace, monospace;padding:9px 4px">$12,300</td><td style="border-bottom:1px solid #F4F4F4;padding:9px 4px;text-align:right"><span style="border-radius:999px;font-size:11px;font-weight:600;padding:3px 10px;background-color:#DA1E28;color:#FFFFFF">Blocked</span></td></tr></tbody></table><div style="margin-top:12px"><span style="color:#0F62FE;font-size:13px">View all activity →</span></div></section></div></main></div><div style="align-items:center;background-color:#F4F4F4;display:flex;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;justify-content:center;min-height:640px;padding:32px"><div style="background-color:#FFFFFF;border:1px solid #F4F4F4;border-radius:4px;display:grid;grid-template-columns:1fr 1fr;max-width:860px;overflow:hidden;width:100%"><div style="background-color:#0F62FE;color:#FFFFFF;display:flex;flex-direction:column;gap:16px;justify-content:flex-end;padding:32px"><span style="background-color:#FFFFFF;border-radius:4px;height:28px;opacity:0.9;width:28px"></span><div style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:28px;font-weight:600;line-height:1.2">Ship on-system UI from day one.</div><div style="font-size:14px">One account for every workspace, report, and integration in Fixture.</div></div><div style="display:flex;flex-direction:column;gap:16px;padding:32px"><div><h1 style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:22px;font-weight:600;margin:0">Sign in</h1><div style="color:#161616;font-size:13px;margin-top:6px">New here? <span style="color:#0F62FE">Create an account</span></div></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#161616;font-size:12px;letter-spacing:0.02em">Email</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#161616;font-size:14px;padding:10.4px 12px">ada@example.com</span></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#161616;font-size:12px;letter-spacing:0.02em">Password</span><span style="background-color:#F4F4F4;border:1px solid #0F62FE;border-radius:4px;box-shadow:0 0 0 2px #0F62FE33;color:#161616;font-size:14px;padding:10.4px 12px">••••••••••</span></div><div style="align-items:center;display:flex;justify-content:space-between"><span style="align-items:center;display:inline-flex;gap:8px"><span style="background-color:#0F62FE;border-radius:999px;display:inline-flex;height:20px;justify-content:flex-end;padding:2px;width:36px"><span style="background-color:#FFFFFF;border-radius:999px;height:16px;width:16px"></span></span><span style="color:#161616;font-size:13px">Remember me</span></span><span style="color:#0F62FE;font-size:13px">Forgot password?</span></div><span style="border-radius:4px;display:inline-block;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;background-color:#0F62FE;color:#FFFFFF">Sign in</span><div style="align-items:center;display:flex;gap:12px"><span style="background-color:#F4F4F4;flex:1;height:1px"></span><span style="color:#161616;font-size:12px">or</span><span style="background-color:#F4F4F4;flex:1;height:1px"></span></div><span style="border-radius:4px;display:inline-block;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;border:1px solid #F4F4F4;color:#161616">Continue with SSO</span><div style="color:#161616;font-size:12px;line-height:1.5">Protected by two-factor authentication. By continuing you agree to the terms of service.</div></div></div></div><div style="background-color:#FFFFFF;color:#161616;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;min-height:640px;padding:24px"><div style="margin:0 auto;max-width:760px"><div style="color:#161616;font-size:12px;margin-bottom:4px">Fixture / Settings</div><h1 style="font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:24px;font-weight:600;margin:0">Account settings</h1><div style="border-bottom:1px solid #F4F4F4;display:flex;gap:4px;margin-top:16px"><span style="border-bottom:2px solid #0F62FE;color:#161616;font-size:14px;font-weight:600;padding:9.6px 12px">Profile</span><span style="border-bottom:2px solid transparent;color:#161616;font-size:14px;font-weight:400;padding:9.6px 12px">Workspace</span><span style="border-bottom:2px solid transparent;color:#161616;font-size:14px;font-weight:400;padding:9.6px 12px">Notifications</span><span style="border-bottom:2px solid transparent;color:#161616;font-size:14px;font-weight:400;padding:9.6px 12px">Billing</span><span style="border-bottom:2px solid transparent;color:#161616;font-size:14px;font-weight:400;padding:9.6px 12px">API</span></div><section style="display:flex;flex-direction:column;gap:16px;padding-top:20px"><div style="align-items:center;display:flex;gap:16px"><span style="align-items:center;background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:999px;color:#161616;display:inline-flex;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:22px;font-weight:600;height:56px;justify-content:center;width:56px">A</span><div><div style="font-size:15px;font-weight:600">Ada Lovelace</div><div style="color:#161616;font-size:13px">Owner · joined March 2025</div></div><span style="margin-left:auto"><span style="border-radius:4px;display:inline-block;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;border:1px solid #F4F4F4;color:#161616">Change avatar</span></span></div><div style="display:grid;gap:16px;grid-template-columns:1fr 1fr"><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#161616;font-size:12px;letter-spacing:0.02em">Full name</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#161616;font-size:14px;padding:10.4px 12px">Ada Lovelace</span></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#161616;font-size:12px;letter-spacing:0.02em">Email</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#161616;font-size:14px;padding:10.4px 12px">ada@example.com</span></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#161616;font-size:12px;letter-spacing:0.02em">Role</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#161616;font-size:14px;padding:10.4px 12px">Owner</span></div><div style="display:flex;flex-direction:column;gap:6px"><span style="color:#161616;font-size:12px;letter-spacing:0.02em">Timezone</span><span style="background-color:#F4F4F4;border:1px solid #F4F4F4;border-radius:4px;color:#161616;font-size:14px;padding:10.4px 12px">UTC+03:00 — Riyadh</span></div></div><div style="background-color:#F4F4F4;border-radius:4px;display:flex;flex-direction:column;gap:12px;padding:16px"><div style="align-items:center;display:flex;gap:16px"><div style="flex:1"><div style="font-size:14px;font-weight:500">Product updates</div><div style="color:#161616;font-size:12px">Release notes and new catalog entries</div></div><span style="background-color:#0F62FE;border-radius:999px;display:inline-flex;height:20px;justify-content:flex-end;padding:2px;width:36px"><span style="background-color:#FFFFFF;border-radius:999px;height:16px;width:16px"></span></span></div><div style="align-items:center;display:flex;gap:16px"><div style="flex:1"><div style="font-size:14px;font-weight:500">Usage reports</div><div style="color:#161616;font-size:12px">Weekly summary of fetches and installs</div></div><span style="background-color:#0F62FE;border-radius:999px;display:inline-flex;height:20px;justify-content:flex-end;padding:2px;width:36px"><span style="background-color:#FFFFFF;border-radius:999px;height:16px;width:16px"></span></span></div><div style="align-items:center;display:flex;gap:16px"><div style="flex:1"><div style="font-size:14px;font-weight:500">Security alerts</div><div style="color:#161616;font-size:12px">Sign-ins from new devices</div></div><span style="background-color:#F4F4F4;border-radius:999px;display:inline-flex;height:20px;justify-content:flex-start;padding:2px;width:36px"><span style="background-color:#FFFFFF;border-radius:999px;height:16px;width:16px"></span></span></div></div><div style="border:1px solid #DA1E28;border-radius:4px;display:flex;gap:16px;justify-content:space-between;padding:16px"><div><div style="color:#DA1E28;font-size:14px;font-weight:600">Delete workspace</div><div style="color:#161616;font-size:12px;margin-top:4px">Removes every report and API key. This cannot be undone.</div></div><span style="border-radius:4px;display:inline-block;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;background-color:#DA1E28;color:#FFFFFF">Delete</span></div><div style="display:flex;gap:10px;justify-content:flex-end"><span style="border-radius:4px;display:inline-block;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;border:1px solid #F4F4F4;color:#161616">Cancel</span><span style="border-radius:4px;display:inline-block;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;background-color:#0F62FE;color:#FFFFFF">Save changes</span></div></section></div></div></div>"`;
