exports[`sample templates > renders every template for the brand-look fixture (snapshot) 1`] = `"<div><div style="background-color:#F6F9FC;color:#0A2540;display:grid;font-family:&quot;Inter&quot;, system-ui, sans-serif;grid-template-columns:220px 1fr;min-height:640px"><aside style="border-right:1px solid #F4F4F4;display:flex;flex-direction:column;gap:24px;padding:20px"><div style="align-items:center;display:flex;gap:10px"><span style="background-color:#0A2540;border-radius:4px;height:22px;width:22px"></span><span style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:15px;font-weight:700">Fixture</span></div><nav style="display:flex;flex-direction:column;gap:4px"><span style="background-color:#F4F4F4;border-left:3px solid #0A2540;border-radius:4px;color:#0A2540;font-size:14px;padding:8px 12px">Overview</span><span style="border-left:3px solid transparent;border-radius:4px;color:#0A2540;font-size:14px;padding:8px 12px">Reports</span><span style="border-left:3px solid transparent;border-radius:4px;color:#0A2540;font-size:14px;padding:8px 12px">Customers</span><span style="border-left:3px solid transparent;border-radius:4px;color:#0A2540;font-size:14px;padding:8px 12px">Billing</span><span style="border-left:3px solid transparent;border-radius:4px;color:#0A2540;font-size:14px;padding:8px 12px">Settings</span></nav><div style="border-top:1px solid #F4F4F4;margin-top:auto;padding-top:16px"><span style="color:#0A2540;font-size:12px">help@example.com</span></div></aside><main style="display:flex;flex-direction:column;gap:24px;padding:24px"><header style="align-items:center;display:flex;justify-content:space-between"><div><div style="color:#0A2540;font-size:12px;margin-bottom:4px">Analytics / Revenue</div><h1 style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:24px;font-weight:700;margin:0">Revenue dashboard</h1></div><div style="display:flex;gap:10px"><span style="border-radius:4px;display:inline-block;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;border:1px solid #F4F4F4;color:#0A2540">Export</span><span style="border-radius:4px;display:inline-block;font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:14px;font-weight:500;line-height:1;padding:12px 16px;background-color:#0A2540;color:#FFFFFF">Create report</span></div></header><div style="display:grid;gap:16px;grid-template-columns:repeat(4, 1fr)"><div style="background-color:#F4F4F4;border-radius:8px;padding:16px"><div style="color:#0A2540;font-size:12px">Revenue</div><div style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:26px;font-weight:700;margin-top:8px">$128.4K</div><div style="color:#0A2540;font-size:12px;margin-top:8px">▲ 12.5% vs last month</div></div><div style="background-color:#F4F4F4;border-radius:8px;padding:16px"><div style="color:#0A2540;font-size:12px">Customers</div><div style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:26px;font-weight:700;margin-top:8px">2,847</div><div style="color:#0A2540;font-size:12px;margin-top:8px">▲ 8.1% vs last month</div></div><div style="background-color:#F4F4F4;border-radius:8px;padding:16px"><div style="color:#0A2540;font-size:12px">Average order</div><div style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:26px;font-weight:700;margin-top:8px">$45.10</div><div style="color:#0A2540;font-size:12px;margin-top:8px">▲ 3.2% vs last month</div></div><div style="background-color:#F4F4F4;border-radius:8px;padding:16px"><div style="color:#0A2540;font-size:12px">Churn</div><div style="font-family:&quot;Inter&quot;, system-ui, sans-serif;font-size:26px;font-weight:700;margin-top:8px">1.9%</div><div style="color:#DA1E28;font-size:12px;margin-top:8px">▲ 0.2% vs last month</div></div></div><div style="display:grid;gap:16px;grid-template-columns:3fr 2fr"><section style="border:1px solid #F4F4F4;border-radius:8px;padding:16px"><h2 style="font-size:14px;font-weight:600;margin:0 0 16px