ont-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0">rounded</td><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0;overflow-wrap:anywhere">{rounded.none}</td></tr><tr><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0;vertical-align:top"></td><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0">padding</td><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0;overflow-wrap:anywhere">12px 16px</td></tr><tr><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0;vertical-align:top">input</td><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0">backgroundColor</td><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0;overflow-wrap:anywhere">{colors.surface}</td></tr><tr><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0;vertical-align:top"></td><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0">textColor</td><td style="font-family:var(--font-mono, ui-monospace, monospace);font-size:0.75rem;color:var(--color-on-surface-variant, #57503F);padding:6px 12px 6px 0;overflow-wrap:anywhere">{colors.on-surface}</td></tr></tbody></table><div style="align-items:center;display:flex;gap:12px"><span aria-hidden="true" style="align-items:center;border:1px solid var(--color-border, #E3DBC9);border-radius:6px;display:inline-flex;font-family:&quot;IBM Plex Sans&quot;, system-ui, sans-serif;font-size:1.375rem;font-weight:600;height:40px;justify-content:center;width:40px">F</span><span aria-hidden="true" style="display:inline-flex;gap:4px"><span style="background-color:#0F62FE;border:1px solid var(--color-border, #E3DBC9);border-radius:4px;display:inline-block;height:20px;width:20px"></span><span style="background-color:#FFFFFF;border:1px solid var(--color-border, #E3DBC9);border-radius:4px;display:inline-block;height:20px;width:20px"></span><span style="background-color:#FFFFFF;border:1px solid var(--color-border, #E3DBC9);border-radius:4px;display:inline-block;height:20px;width:20px"></span><span style="background-color:#161616;border:1px solid var(--color-border, #E3DBC9);border-radius:4px;display:inline-block;height:20px;width:20px"></span><span style="background-color:#DA1E28;border:1px solid var(--color-border, #E3DBC9);border-radius:4px;display:inline-block;height:20px;width:20px"></span></span></div></div>"`;
