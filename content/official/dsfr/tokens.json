{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "The French state's design system — blue-france and red-marianne on white, square corners, and an accessibility mandate; reference-only outside French government services.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0.569
        ],
        "hex": "#000091"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "primary-soft": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.89,
          0.89,
          0.992
        ],
        "hex": "#e3e3fd"
      }
    },
    "red-marianne": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.882,
          0,
          0.059
        ],
        "hex": "#e1000f"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "surface-alt": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.965,
          0.965,
          0.965
        ],
        "hex": "#f6f6f6"
      }
    },
    "surface-contrast": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.933,
          0.933,
          0.933
        ],
        "hex": "#eeeeee"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.227,
          0.227,
          0.227
        ],
        "hex": "#3a3a3a"
      }
    },
    "on-surface-title": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.086,
          0.086,
          0.086
        ],
        "hex": "#161616"
      }
    },
    "on-surface-mention": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.4,
          0.4,
          0.4
        ],
        "hex": "#666666"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.867,
          0.867,
          0.867
        ],
        "hex": "#dddddd"
      }
    },
    "info": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.388,
          0.796
        ],
        "hex": "#0063cb"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.094,
          0.459,
          0.235
        ],
        "hex": "#18753c"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.702,
          0.251,
          0
        ],
        "hex": "#b34000"
      }
    },
    "error": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.808,
          0.02,
          0
        ],
        "hex": "#ce0500"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xxs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "xs": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "3xl": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "none": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Public Sans",
        "fontSize": {
          "value": 2.5,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "heading-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Public Sans",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Public Sans",
        "fontSize": {
          "value": 1.75,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Public Sans",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Public Sans",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Public Sans",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    }
  }
}
