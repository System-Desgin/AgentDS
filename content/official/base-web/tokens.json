{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Uber's design system — a stark black-and-white base with an electric blue accent, built for scale.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ],
        "hex": "#000000"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.153,
          0.431,
          0.945
        ],
        "hex": "#276ef1"
      }
    },
    "on-accent": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ],
        "hex": "#000000"
      }
    },
    "on-surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.329,
          0.329,
          0.329
        ],
        "hex": "#545454"
      }
    },
    "surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.965,
          0.965,
          0.965
        ],
        "hex": "#f6f6f6"
      }
    },
    "fill": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.933,
          0.933,
          0.933
        ],
        "hex": "#eeeeee"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.796,
          0.796,
          0.796
        ],
        "hex": "#cbcbcb"
      }
    },
    "positive": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.016,
          0.533,
          0.282
        ],
        "hex": "#048848"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.753,
          0.263
        ],
        "hex": "#ffc043"
      }
    },
    "negative": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.882,
          0.098,
          0
        ],
        "hex": "#e11900"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xxs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "xs": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 2.5,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "title": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.25,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 500
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    }
  }
}
