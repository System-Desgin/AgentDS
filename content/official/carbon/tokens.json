{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "IBM's design system — precise, functional, and enterprise-scale, led by IBM Blue on a neutral field.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.384,
          0.996
        ],
        "hex": "#0f62fe"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.086,
          0.086,
          0.086
        ],
        "hex": "#161616"
      }
    },
    "on-surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.322,
          0.322,
          0.322
        ],
        "hex": "#525252"
      }
    },
    "surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.957,
          0.957,
          0.957
        ],
        "hex": "#f4f4f4"
      }
    },
    "helper": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.435,
          0.435,
          0.435
        ],
        "hex": "#6f6f6f"
      }
    },
    "border-subtle": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.878,
          0.878,
          0.878
        ],
        "hex": "#e0e0e0"
      }
    },
    "border-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.553,
          0.553,
          0.553
        ],
        "hex": "#8d8d8d"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.141,
          0.631,
          0.282
        ],
        "hex": "#24a148"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.945,
          0.761,
          0.106
        ],
        "hex": "#f1c21b"
      }
    },
    "error": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.855,
          0.118,
          0.157
        ],
        "hex": "#da1e28"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xxs": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "3xl": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "IBM Plex Sans",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "heading-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "IBM Plex Sans",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "IBM Plex Sans",
        "fontSize": {
          "value": 1.25,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "IBM Plex Sans",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "IBM Plex Sans",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "IBM Plex Sans",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 400,
        "letterSpacing": {
          "value": 0.02,
          "unit": "em"
        }
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "IBM Plex Mono",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    }
  }
}
