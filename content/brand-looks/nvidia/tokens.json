{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "The visual language observed on NVIDIA's public site — black and charcoal surfaces, one signature green, squared corners, and dense spec tables.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.463,
          0.725,
          0
        ],
        "hex": "#76b900"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ],
        "hex": "#000000"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ],
        "hex": "#000000"
      }
    },
    "surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.102,
          0.102,
          0.102
        ],
        "hex": "#1a1a1a"
      }
    },
    "surface-muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.149,
          0.149,
          0.149
        ],
        "hex": "#262626"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.8,
          0.8,
          0.8
        ],
        "hex": "#cccccc"
      }
    },
    "helper": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.6,
          0.6,
          0.6
        ],
        "hex": "#999999"
      }
    },
    "border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.2,
          0.2,
          0.2
        ],
        "hex": "#333333"
      }
    },
    "border-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.4,
          0.4,
          0.4
        ],
        "hex": "#666666"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.463,
          0.725,
          0
        ],
        "hex": "#76b900"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.702,
          0
        ],
        "hex": "#ffb300"
      }
    },
    "error": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          0.322,
          0.322
        ],
        "hex": "#ff5252"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xxs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "xs": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 12,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 48,
        "unit": "px"
      }
    },
    "3xl": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 0,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Work Sans",
        "fontSize": {
          "value": 3,
          "unit": "rem"
        },
        "fontWeight": 700,
        "letterSpacing": {
          "value": -0.01,
          "unit": "em"
        }
      }
    },
    "heading-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Work Sans",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 700
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Work Sans",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Work Sans",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Work Sans",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Work Sans",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": 0.08,
          "unit": "em"
        }
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    }
  }
}
