{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Observed dark-first look of supabase.com — near-black surfaces, one signature green accent with dark text on fills, hairline borders, code-forward type.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.243,
          0.812,
          0.557
        ],
        "hex": "#3ecf8e"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.059,
          0.059
        ],
        "hex": "#0f0f0f"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.071,
          0.071,
          0.071
        ],
        "hex": "#121212"
      }
    },
    "surface-deep": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.059,
          0.059
        ],
        "hex": "#0f0f0f"
      }
    },
    "surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.11,
          0.11,
          0.11
        ],
        "hex": "#1c1c1c"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.98,
          0.98,
          0.98
        ],
        "hex": "#fafafa"
      }
    },
    "on-surface-variant": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.537,
          0.537,
          0.537
        ],
        "hex": "#898989"
      }
    },
    "border-subtle": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.18,
          0.18,
          0.18
        ],
        "hex": "#2e2e2e"
      }
    },
    "border-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.243,
          0.243,
          0.243
        ],
        "hex": "#3e3e3e"
      }
    },
    "success": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.243,
          0.812,
          0.557
        ],
        "hex": "#3ecf8e"
      }
    },
    "warning": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.961,
          0.651,
          0.137
        ],
        "hex": "#f5a623"
      }
    },
    "error": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.973,
          0.443,
          0.443
        ],
        "hex": "#f87171"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xxs": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    },
    "2xl": {
      "$value": {
        "value": 64,
        "unit": "px"
      }
    },
    "3xl": {
      "$value": {
        "value": 96,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "full": {
      "$value": {
        "value": 9999,
        "unit": "px"
      }
    }
  },
  "typography": {
    "display": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 3.5,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.02,
          "unit": "em"
        }
      }
    },
    "heading-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 2,
          "unit": "rem"
        },
        "fontWeight": 600,
        "letterSpacing": {
          "value": -0.01,
          "unit": "em"
        }
      }
    },
    "heading": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1.5,
          "unit": "rem"
        },
        "fontWeight": 600
      }
    },
    "body": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 1,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "body-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    },
    "label": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Inter",
        "fontSize": {
          "value": 0.75,
          "unit": "rem"
        },
        "fontWeight": 500
      }
    },
    "code": {
      "$type": "typography",
      "$value": {
        "fontFamily": "JetBrains Mono",
        "fontSize": {
          "value": 0.875,
          "unit": "rem"
        },
        "fontWeight": 400
      }
    }
  }
}
