# Root environment for docker-compose (the backend stack).
# Copy to .env before running `docker compose up`. Never commit a real .env.

# --- PostgreSQL ---
POSTGRES_USER=agentds
POSTGRES_PASSWORD=change-me
POSTGRES_DB=agentds

# --- API ---
# Public hostname Traefik routes to the api service (Dokploy production).
API_DOMAIN=api.agent-ds.oday-bakkour.com
# Open CORS for public GET traffic ("*" or comma-separated origins).
CORS_ORIGIN=*
# Bearer token for POST /internal/ingest (Phase 2). Leave empty in Phase 0.
INGEST_TOKEN=
LOG_LEVEL=info
