# apps/api environment — copy to apps/api/.env for local dev.
# Secrets live only in Dokploy in production; never commit a real .env.

# development | test | production
NODE_ENV=development
PORT=4000

# PostgreSQL. Optional in Phase 0 (API boots without a DB); required from Phase 2.
# Local example (matches docker-compose service names):
DATABASE_URL=postgresql://agentds:change-me@localhost:5432/agentds?schema=public

# Open CORS for public GET traffic. "*" or a comma-separated origin list.
CORS_ORIGIN=*

# Bearer token for POST /internal/ingest (wired in Phase 2). Leave unset in dev.
INGEST_TOKEN=

# Rate limiting (per IP).
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=60

# fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# NEVER set ANTHROPIC_API_KEY here or anywhere in this repo (see CLAUDE.md).

# Phase 2 additions
# Comma-separated IPs allowed to call POST /internal/ingest (default loopback).
INGEST_IP_ALLOWLIST=
# Content directory override (Docker bakes /app/content; dev auto-resolves).
CONTENT_DIR=
# File-route throttle ceiling (PRD F-4: 120/min; global default is 60/min).
RATE_LIMIT_FILES_LIMIT=
# Set to 1 to skip the boot-time ingest (tests / debugging).
SKIP_BOOT_INGEST=
