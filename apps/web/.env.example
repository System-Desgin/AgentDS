# apps/web environment — copy to apps/web/.env.local for local dev.
# Public vars are inlined at build time; never put secrets in NEXT_PUBLIC_*.

# Base URL of the AgentDS fetch API.
NEXT_PUBLIC_API_URL=https://api.agent-ds.oday-bakkour.com

# Disable Next.js telemetry in CI/containers.
NEXT_TELEMETRY_DISABLED=1

# Phase 3 additions
# Canonical site origin (metadata, sitemap, JSON-LD).
NEXT_PUBLIC_SITE_URL=https://agent-ds.oday-bakkour.com
# Bearer token for POST /api/revalidate (ingest-triggered ISR refresh).
REVALIDATE_TOKEN=
# Self-hosted Umami (both required before the script renders).
NEXT_PUBLIC_UMAMI_SRC=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
