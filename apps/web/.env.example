# apps/web environment — copy to apps/web/.env.local for local dev.
# Public vars are inlined at build time; never put secrets in NEXT_PUBLIC_*.

# Base URL of the AgentDS fetch API.
NEXT_PUBLIC_API_URL=https://api.agent-ds.oday-bakkour.com

# Disable Next.js telemetry in CI/containers.
NEXT_TELEMETRY_DISABLED=1
