# Dependencies
node_modules/
.pnpm-store/

# Build output
dist/
build/
.next/
out/
*.tsbuildinfo

# Next.js generated types (auto-created on dev/build)
next-env.d.ts

# Pipeline intermediate/build artifacts (regenerated by extract/export; the
# bundle.zip is pre-built at ingest). Published entry files are DESIGN.md,
# meta.yaml, tokens.json, tailwind.css, QA.md, lint-report.json.
content/**/tokens.raw.json
content/**/bundle.zip

# Turborepo
.turbo/

# Test / coverage
coverage/
*.lcov

# Prisma generated client (regenerated on install/build)
apps/api/src/generated/

# Environment — never commit real secrets; only *.example is tracked
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
pnpm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Misc
*.pem
.vercel/

# API test fixtures: bundle.zip is produced by ingest during test runs
apps/api/test/fixtures/content/**/bundle.zip
